# Supabase — copie este arquivo para .env.local e preencha com suas credenciais
# Encontre em: https://supabase.com/dashboard > Project > Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# URL do site (usado em redirecionamentos de auth)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
